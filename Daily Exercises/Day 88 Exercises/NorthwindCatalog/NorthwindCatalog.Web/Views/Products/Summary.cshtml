@model IEnumerable<NorthwindCatalog.Services.Dtos.CategorySummaryDto>

<div class="container mt-4">
    <h2 class="mb-4">Northwind Analytics Summary</h2>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Category</th>
                <th>Total Products</th>
                <th>Average Price</th>
                <th>Top Product</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.CategoryName</td>
                    <td>@s.ProductCount</td>
                    <td>@s.AvgPrice.ToString("C2")</td>
                    <td>@s.MostExpensiveProduct</td>
                </tr>
            }
        </tbody>
    </table>
</div>
