@model List<CarManagementMVCApplication.Models.ManageUserRolesViewModel>

@{
    ViewData["Title"] = "Manage Roles";
    var userId = ViewBag.userId;
    var userName = ViewBag.UserName;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Dashboard" class="text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Manage Roles</li>
                </ol>
            </nav>

            <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
                <div class="card-header bg-dark text-white p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary p-3 rounded-circle me-4 shadow">
                            <i class="bi bi-person-badge-fill text-white fs-2"></i>
                        </div>
                        <div>
                            <h3 class="mb-0 fw-bold">Manage Roles</h3>
                            <p class="mb-0 text-white-50">Configuring permissions for: <strong>@userName</strong></p>
                        </div>
                    </div>
                </div>
                
                <form method="post">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="text-secondary mb-4 pb-2 border-bottom">System Permission Groups</h5>
                        <input type="hidden" name="userId" value="@userId" />
                        
                        <div class="row g-4">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <div class="col-12">
                                    <div class="role-card p-3 rounded-3 border d-flex justify-content-between align-items-center transition-all bg-light">
                                        <div class="d-flex align-items-center">
                                            <div class="role-icon me-3 bg-white p-2 rounded shadow-sm text-primary">
                                                <i class="bi @(Model[i].RoleName == "Admin" ? "bi-star-fill text-danger" : Model[i].RoleName == "Customer" ? "bi-cart-fill text-success" : "bi-eye-fill text-info") fs-4"></i>
                                            </div>
                                            <div>
                                                <input type="hidden" asp-for="@Model[i].RoleId" />
                                                <input type="hidden" asp-for="@Model[i].RoleName" />
                                                <label class="form-check-label fw-bold d-block mb-1" asp-for="@Model[i].Selected">
                                                    @Model[i].RoleName Access
                                                </label>
                                                <span class="text-muted small">
                                                    @(Model[i].RoleName == "Admin" ? "Full system oversight, CRUD operations, and user role management." : 
                                                      Model[i].RoleName == "Customer" ? "Access to browse inventory and create new car entries." : 
                                                      "Read-only access to view the car management database.")
                                                </span>
                                            </div>
                                        </div>
                                        <div class="form-check form-switch fs-3">
                                            <input asp-for="@Model[i].Selected" class="form-check-input accent-primary" role="switch" />
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <div asp-validation-summary="All" class="text-danger mt-4 small border rounded p-3 bg-light @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>
                    </div>
                    
                    <div class="card-footer bg-white p-4 d-flex justify-content-between border-top">
                        <a asp-action="Dashboard" asp-controller="Account" class="btn btn-light px-4 border">
                            <i class="bi bi-arrow-left me-2"></i>Dashboard
                        </a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm fw-bold">
                            <i class="bi bi-cloud-arrow-up-fill me-2"></i>Commit Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .role-card {
        border-color: #eee !important;
        transition: all 0.2s ease-in-out;
    }
    .role-card:hover {
        border-color: #0d6efd !important;
        background-color: #f8fbff !important;
        transform: scale(1.01);
    }
    .form-check-input:checked {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }
    .role-icon {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
