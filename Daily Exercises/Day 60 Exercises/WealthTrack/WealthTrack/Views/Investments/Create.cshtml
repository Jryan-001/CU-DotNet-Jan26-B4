@model WealthTrack.ViewModel.InvestmentCreateViewModel
@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Investment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TickerSymbol" class="control-label"></label>
                <input asp-for="TickerSymbol" class="form-control" />
                <span asp-validation-for="TickerSymbol" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AssetName" class="control-label"></label>
                <input asp-for="AssetName" class="form-control" />
                <span asp-validation-for="AssetName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price" class="control-label"></label>
                <input asp-for="Price" id="priceInput" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" id="qtyInput" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <label class="control-label" style="font-weight: bold;">Total Value:</label>
                <input id="totalValueDisplay" class="form-control" readonly value="₹0.00" style="background-color: #f8f9fa;" />
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>

    const priceInput = document.getElementById('priceInput');
    const qtyInput = document.getElementById('qtyInput');
    const displayBox = document.getElementById('totalValueDisplay');
    function calculateTotal() {

        const price = parseFloat(priceInput.value) || 0;
        const quantity = parseInt(qtyInput.value) || 0;
            

        const total = price * quantity;
            

        displayBox.value = new Intl.NumberFormat('en-IN', {
            style: 'currency',
            currency: 'INR'
        }).format(total);
    }

    priceInput.addEventListener('input', calculateTotal);
    qtyInput.addEventListener('input', calculateTotal);
</script>

