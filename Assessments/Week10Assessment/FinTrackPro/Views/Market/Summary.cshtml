
@{
    ViewData["Title"] = "Market Summary";
}

<h1>Market Summary</h1>

@if (ViewBag.MarketStatus == "Open")
{
    <div class="alert alert-success" role="alert">
        <strong>Market Status:</strong> @ViewBag.MarketStatus
    </div>
}
else
{
    <div class="alert alert-danger" role="alert">
        <strong>Market Status:</strong> @ViewBag.MarketStatus
    </div>
}

<div class="card" style="width: 20rem;">
    <div class="card-body">
        <h5 class="card-title">Top Gainer</h5>
        <p class="card-text"><strong>Stock:</strong> @ViewData["TopGainer"]</p>
        <p class="card-text"><strong>Volume:</strong> @ViewData["Volume"]</p>
    </div>
</div>