@model FinTrackPro.Models.Transaction
@{
    ViewBag.Title = "Add Transaction";
    var accountId = ViewBag.AccountId;
}
<h2>Add Transaction for Account @accountId</h2>
<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="AccountId" value="@accountId" />
    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" class="form-control" />
    </div>
    <div class="form-group">
        <label>Category</label><br />
        <input type="radio" name="Category" value="Credit" @(Model.Category == "Credit" ? "checked" : "") /> Credit
        <input type="radio" name="Category" value="Debit" @(Model.Category == "Debit" ? "checked" : "") /> Debit
    </div>
    <div class="form-group">
        <label asp-for="Date"></label>
        <input asp-for="Date" class="form-control" type="date" />
    </div>
    <button type="submit" class="btn btn-success">Add Transaction</button>
</form>
