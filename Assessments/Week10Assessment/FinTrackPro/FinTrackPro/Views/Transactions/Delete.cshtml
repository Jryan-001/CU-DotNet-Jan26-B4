@model FinTrackPro.Models.Transaction
@{
    ViewBag.Title = "Delete Transaction";
}
<h2>Delete Transaction</h2>
<div>
    <h4>Are you sure you want to delete this transaction?</h4>
    <dl class="row">
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Amount</dt>
        <dd class="col-sm-10">@Model.Amount</dd>
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.Date.ToShortDateString()</dd>
    </dl>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="@Url.Action("Index", "Transactions", new { accountId = Model.AccountId })" class="btn btn-secondary">Cancel</a>
    </form>
</div>
