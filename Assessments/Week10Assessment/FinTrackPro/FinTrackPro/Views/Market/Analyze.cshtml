@{
    ViewData["Title"] = "Market Analysis";
}
<h1>Market Analysis</h1>
<div class="card" style="width: 25rem;">
    <div class="card-body">
        <h5 class="card-title">Analysis for @ViewBag.Ticker</h5>
        <p class="card-text"><strong>Ticker:</strong> @ViewBag.Ticker</p>
        <p class="card-text"><strong>Analysis Period:</strong> @ViewBag.Days days</p>
    </div>
</div>