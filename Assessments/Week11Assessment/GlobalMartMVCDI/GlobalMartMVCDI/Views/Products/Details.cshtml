@model GlobalMartMVCDI.Models.Product

<div class="container mt-5">
    <div class="card p-4">
        <h2>Product Details: @Model.ProductName</h2>
        <hr />
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Base Price:</strong> @Model.Price.ToString("C")</p>
        
        <div class="mt-3">
            <a href="/Products/Index" class="btn btn-secondary">Back to Store</a>
        </div>
    </div>
</div>
