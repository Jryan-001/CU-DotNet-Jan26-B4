@using GlobalMartMVCDI.Models.ViewModel
<div class="container mt-5">
    <div class="card p-4 shadow-lg border-0">
        <h1 class="text-center mb-4">Final Order Summary</h1>
        <hr />

        <div class="mb-4 text-center">
            <h5 class="mb-3">Have a promo code?</h5>
            <form method="get" action="/Carts/Checkout" class="form-inline justify-content-center">
                <input type="text" name="promoCode" class="form-control mr-2" placeholder="e.g. WINTER25 or FREESHIP"
                       style="width: 300px; border: 2px solid #ffc107;" />
                <button type="submit" class="btn btn-warning font-weight-bold">Apply My Promo</button>
            </form>
            <p class="text-muted small mt-2">Try "WINTER25" for 15% off or "FREESHIP" for $50 off!</p>
        </div>
        <h4 class="mb-3">Chosen Products</h4>
        <table class="table table-hover mb-5">
            <thead class="bg-dark text-white">
                <tr>
                    <th>Product Name</th>
                    <th>Price (Single)</th>
                    <th class="text-center">Quantity</th>
                    <th class="text-right">Total Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in (List<CartViewModel>)ViewBag.CartList)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price.ToString("C")</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-right">@item.Subtotal.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="bg-light p-4 rounded border">
            <div class="row">
                <div class="col-6"><strong>Gross Subtotal:</strong></div>
                <div class="col-6 text-right">@ViewBag.GrandSubtotal.ToString("C")</div>
            </div>
            <div class="row mt-3">
                <div class="col-6"><strong>Promo Code Applied:</strong></div>
                <div class="col-6 text-right" style="color:blue;"><strong>@ViewBag.PromoUsed</strong></div>
            </div>
            <hr />
            <div class="row" style="font-size: 1.8em; color: green; font-weight: bold;">
                <div class="col-6">Grand Total Amount:</div>
                <div class="col-6 text-right">@ViewBag.FinalPrice.ToString("C")</div>
            </div>
        </div>

        <div class="mt-5 text-center">
            <a href="/Products/Index" class="btn btn-secondary btn-lg mr-2">Go Back to Store</a>
            <a href="/Carts/Clear" class="btn btn-danger btn-lg">Clear All Items</a>
            <button class="btn btn-success btn-lg ml-2">Confirm and Purchase</button>
        </div>
    </div>
</div>
