@model FrontendMVC.Models.DestinationViewModel

<div class="container mt-4 text-center">
    <h1 class="text-danger">Delete Destination</h1>
    <h4 class="mt-3">Are you sure you want to delete this?</h4>
    
    <div class="card border-danger shadow-sm mt-4 col-md-8 mx-auto">
        <div class="card-body">
            <h5 class="card-title">@Model.CityName, @Model.Country</h5>
            <p class="card-text">@Model.Description</p>
        </div>
        <div class="card-footer bg-white border-top-0">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
