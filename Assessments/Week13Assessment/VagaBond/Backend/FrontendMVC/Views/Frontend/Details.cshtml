@model FrontendMVC.Models.DestinationViewModel

<div class="container mt-4">
    <h1>Destination Details</h1>
    <div class="card shadow-sm mt-3">
        <div class="card-body">
            <h4 class="card-title">@Model.CityName, @Model.Country</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3 text-muted">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>
                
                <dt class="col-sm-3 text-muted">Rating</dt>
                <dd class="col-sm-9"><span class="badge bg-success">@Model.Rating / 5</span></dd>
                
                <dt class="col-sm-3 text-muted">Last Visited</dt>
                <dd class="col-sm-9">@Model.LastVisited.ToLongDateString()</dd>
            </dl>
        </div>
        <div class="card-footer bg-light text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>
